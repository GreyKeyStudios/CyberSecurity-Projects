# Copy to .env.local for local dev. Set the same values in Cloudflare Pages → Environment variables.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Canonical site URL for auth email links (no trailing slash).
# Set in Cloudflare Pages for production so confirm links never point at localhost.
NEXT_PUBLIC_SITE_URL=https://soc.greykeystudios.dev

# Supabase Auth (dashboard): Authentication → URL configuration
# Site URL: https://soc.greykeystudios.dev (must NOT be localhost in production)
# Redirect URLs (add all that apply):
#   https://soc.greykeystudios.dev/auth/confirm
#   https://os.greykeystudios.dev/auth/confirm
#   http://localhost:3000/auth/confirm

# Supabase Auth (dashboard): Authentication → Email Templates
# Edit subject/body for Confirm signup, Reset password, etc.

# Custom sender (optional): Authentication → SMTP Settings
# Use Resend, SendGrid, AWS SES, etc. to send from your own domain instead of Supabase.

# Keep-alive (free tier pauses after ~7 days of no API activity):
# GitHub repo → Settings → Secrets and variables → Actions → add:
#   SUPABASE_URL, SUPABASE_ANON_KEY
# Workflow: .github/workflows/supabase-keepalive.yml (runs daily; manual trigger in Actions tab)